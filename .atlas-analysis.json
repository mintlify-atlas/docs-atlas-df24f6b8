  "keyFeatures": [
    "Privacy-first medical records on Aleo blockchain",
    "End-to-end encryption for patient data",
    "Time-limited access sharing via QR codes",
    "Temporary doctor access tokens (1 hour to 7 days)",
    "Zero-knowledge proof verification",
    "Patient-controlled access management",
    "Multiple record types (lab results, prescriptions, imaging)",
    "Automatic access expiration enforcement",
    "Manual access revocation",
    "HIPAA-grade data protection"
  ],
  "publicApiSurface": [
    "create_record(data_part1-12, record_type, data_hash, nonce, make_discoverable)",
    "grant_access(medical_record, doctor, duration_blocks, nonce)",
    "verify_access(access_token, doctor, record_id)",
    "revoke_access(access_token)",
    "get_access_info(access_token)",
    "compute_record_id(patient, data_hash, nonce)",
    "compute_access_token(record_id, doctor, patient, nonce)",
    "POST /api/wallet/connect",
    "POST /api/wallet/generate",
    "GET /api/wallet/balance/:sessionId",
    "POST /api/records/create",
    "GET /api/records/fetch/:sessionId",
    "POST /api/access/grant",
    "GET /api/health"
  ]
